{
    "name": "doctor-recommender-app",
    "version": "1.0.0",
    "description": "Full stack doctor recommender application",
    "scripts": {
        "start": "concurrently \"npm run client\" \"npm run server\"",
        "start-all": "concurrently \"npm run client\" \"npm run server\" \"npm run dpdr\"",
        "client": "cd client && npm run dev",
        "server": "cd server && npm run dev",
        "dpdr": "server/DPDR/myenv/bin/python server/DPDR/app.py",
        "install-all": "concurrently \"npm install\" \"cd client && npm install\" \"cd server && npm install\""
    },
    "devDependencies": {
        "concurrently": "^7.6.0"
    }
}